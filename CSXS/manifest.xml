<?xml version="1.0" encoding="UTF-8"?>
<ExtensionManifest
    Version="7.0"
    ExtensionBundleId="com.veobridge.bundle"
    ExtensionBundleVersion="0.1.0"
    ExtensionBundleName="Veo Bridge"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
    <ExtensionList>
        <Extension Id="com.veobridge.panel" Version="0.1.0" />
        <Extension Id="com.veobridge.gallery" Version="0.1.0" />
    </ExtensionList>

    <ExecutionEnvironment>
        <HostList>
            <Host Name="AEFT" Version="[25.0,99.9]" />
        </HostList>
        <LocaleList>
            <Locale Code="All" />
        </LocaleList>
        <RequiredRuntimeList>
            <RequiredRuntime Name="CSXS" Version="11.0" />
        </RequiredRuntimeList>
    </ExecutionEnvironment>

    <DispatchInfoList>
        <Extension Id="com.veobridge.panel">
            <DispatchInfo>
                <Resources>
                    <MainPath>./index.html</MainPath>
                    <ScriptPath>./jsx/host.jsx</ScriptPath>
                    <CEFCommandLine>
                        <Parameter>--enable-nodejs</Parameter>
                        <Parameter>--mixed-context</Parameter>
                    </CEFCommandLine>
                </Resources>
                <Lifecycle>
                    <AutoVisible>true</AutoVisible>
                </Lifecycle>
                <UI>
                    <Type>Panel</Type>
                    <Menu>Veo Bridge</Menu>
                    <Geometry>
                        <Size>
                            <Width>360</Width>
                            <Height>540</Height>
                        </Size>
                    </Geometry>
                </UI>
            </DispatchInfo>
        </Extension>

        <Extension Id="com.veobridge.gallery">
            <DispatchInfo>
                <Resources>
                    <MainPath>./gallery.html</MainPath>
                    <ScriptPath>./jsx/host.jsx</ScriptPath>
                    <CEFCommandLine>
                        <Parameter>--enable-nodejs</Parameter>
                        <Parameter>--mixed-context</Parameter>
                    </CEFCommandLine>
                </Resources>
                <Lifecycle>
                    <AutoVisible>false</AutoVisible>
                </Lifecycle>
                <UI>
                    <Type>Modeless</Type>
                    <Menu>Veo Bridge Gallery</Menu>
                    <Geometry>
                        <MinSize>
                            <Width>620</Width>
                            <Height>460</Height>
                        </MinSize>
                        <Size>
                            <Width>980</Width>
                            <Height>700</Height>
                        </Size>
                        <MaxSize>
                            <Width>1920</Width>
                            <Height>1400</Height>
                        </MaxSize>
                    </Geometry>
                </UI>
            </DispatchInfo>
        </Extension>
    </DispatchInfoList>
</ExtensionManifest>
